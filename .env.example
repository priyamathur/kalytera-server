# Kalytera Configuration
# Copy this file to .env and fill in your values
# Never commit .env to git

# Required: Anthropic API key (used by the LLM judge)
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# Required for Docker self-host: PostgreSQL password
POSTGRES_PASSWORD=choose-a-strong-password-here

# Database connection
# Local dev (SQLite, zero config):       leave as-is
# Docker / self-hosted (PostgreSQL):     postgresql://kalytera:<POSTGRES_PASSWORD>@postgres:5432/kalytera
# Render (PostgreSQL):                   set automatically by Render
DATABASE_URL=sqlite:///./kalytera.db

# SDK auth key — SDK callers must send: Authorization: Bearer <key>
# Leave empty to allow all requests (dev mode / no auth)
KALYTERA_API_KEY=

# Dashboard: URL of the Kalytera API (used by Streamlit to call analytics endpoints)
# Local dev:     http://localhost:8000
# Docker:        http://api:8000
# Render:        https://kalytera-api-z9it.onrender.com
KALYTERA_API_ENDPOINT=http://localhost:8000

# Set to "true" to auto-seed 500 demo sessions when API starts and DB is empty
SEED_ON_STARTUP=false
