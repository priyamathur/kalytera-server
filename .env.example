# AgentIQ environment configuration
# Copy to .env and fill in values

# --- Database ---
# SQLite (default — zero setup, good for local dev and demo)
DATABASE_URL=sqlite:///./agentiq.db

# PostgreSQL (for production — uncomment and fill in)
# DATABASE_URL=postgresql://user:password@localhost:5432/agentiq

# --- Auth ---
# API key for POST /trace and GET /agents/{id}/patterns
# If unset, all requests are allowed (dev mode)
AGENTIQ_API_KEY=your-secret-key-here

# --- Anthropic (required for judge.py to score interactions) ---
ANTHROPIC_API_KEY=your-anthropic-api-key-here
